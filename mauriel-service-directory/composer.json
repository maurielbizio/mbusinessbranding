{
    "name": "mbusiness/mauriel-service-directory",
    "description": "AI-powered local service directory WordPress plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "stripe/stripe-php": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mauriel\\": "includes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
